{
  "name": "one-way-git-sync",
  "version": "0.0.0-semantically-released",
  "description": "A tool for synchronizing a destination git repository with a source git repository SAFELY.",
  "keywords": [
    "git",
    "sync"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/one-way-git-sync.git"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "type": "module",
  "bin": "./bin/index.js",
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "build": "build-ts app",
    "cleanup": "yarn format && yarn lint-fix",
    "format": "sort-package-json && yarn format-code",
    "format-code": "oxfmt --write --no-error-on-unmatched-pattern . '!**/package.json'",
    "lint": "oxlint --no-error-on-unmatched-pattern .",
    "lint-fix": "yarn lint --fix",
    "prepare": "lefthook install || true",
    "release": "yarn build && semantic-release",
    "start": "build-ts run src/index.ts --",
    "start-prod": "yarn build && yarn one-way-git-sync",
    "test": "vitest",
    "typecheck": "wb typecheck",
    "verify": "wb verify",
    "verify-full": "wb verify --full"
  },
  "dependencies": {
    "fs-extra": "11.3.5",
    "micromatch": "4.0.8",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "simple-git": "3.36.0",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/node-ts": "23.6.4",
    "@types/fs-extra": "11.0.4",
    "@types/micromatch": "4.0.10",
    "@types/node": "25.9.3",
    "@types/yargs": "17.0.35",
    "@typescript/native-preview": "7.0.0-dev.20260614.1",
    "@willbooster/oxfmt-config": "1.2.2",
    "@willbooster/oxlint-config": "1.4.8",
    "@willbooster/wb": "13.22.18",
    "build-ts": "17.1.24",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "lefthook": "2.1.9",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "oxlint-tsgolint": "0.23.0",
    "semantic-release": "25.0.5",
    "sort-package-json": "4.0.0",
    "vitest": "4.1.9"
  },
  "packageManager": "yarn@4.17.0",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
