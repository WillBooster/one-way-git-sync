{
  "name": "one-way-git-sync",
  "version": "0.0.0-semantically-released",
  "description": "A tool for synchronizing a destination git repository with a source git repository SAFELY.",
  "keywords": [
    "git",
    "sync"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/one-way-git-sync.git"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "type": "module",
  "bin": "./bin/index.js",
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "build": "build-ts app",
    "check-all-for-ai": "yarn check-for-ai && yarn test",
    "check-for-ai": "yarn install > /dev/null && yarn format > /dev/null 2> /dev/null || true && yarn typecheck && yarn lint-fix --quiet",
    "cleanup": "yarn format && yarn lint-fix",
    "format": "sort-package-json && yarn prettify",
    "lint": "eslint --color",
    "lint-fix": "yarn lint --fix",
    "prepare": "lefthook install || true",
    "prettify": "prettier --cache --color --write \"**/{.*/,}*.{cjs,css,cts,htm,html,java,js,json,json5,jsonc,jsx,md,mjs,mts,scss,ts,tsx,vue,yaml,yml}\" \"!**/test{-,/}fixtures/**\" || true",
    "release": "yarn build && semantic-release",
    "start": "build-ts run src/index.ts --",
    "start-prod": "yarn build && yarn one-way-git-sync",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "prettier": "@willbooster/prettier-config",
  "dependencies": {
    "fs-extra": "11.3.4",
    "micromatch": "4.0.8",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "simple-git": "3.33.0",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tsconfig/node-lts": "*",
    "@tsconfig/node-ts": "*",
    "@types/eslint": "9.6.1",
    "@types/fs-extra": "11.0.4",
    "@types/micromatch": "4.0.10",
    "@types/node": "*",
    "@types/yargs": "17.0.35",
    "@willbooster/eslint-config-ts": "11.5.0",
    "@willbooster/prettier-config": "10.3.0",
    "build-ts": "17.0.24",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "eslint": "9.39.1",
    "eslint-config-flat-gitignore": "2.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-sort-class-members": "1.21.0",
    "eslint-plugin-sort-destructure-keys": "3.0.0",
    "eslint-plugin-unicorn": "64.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.4.0",
    "lefthook": "*",
    "prettier": "3.8.1",
    "prettier-plugin-java": "2.8.1",
    "semantic-release": "25.0.3",
    "sort-package-json": "3.6.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "vitest": "4.1.2"
  },
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
