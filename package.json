{
  "name": "one-way-git-sync",
  "version": "0.0.0-semantically-released",
  "description": "A tool for synchronizing a destination git repository with a source git repository SAFELY.",
  "keywords": [
    "git",
    "sync"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/one-way-git-sync.git"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "type": "module",
  "bin": "./bin/index.js",
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "build": "build-ts app",
    "cleanup": "bun wb lint --fix --format",
    "format": "bun wb lint --format",
    "lint": "bun wb lint",
    "lint-fix": "bun wb lint --fix",
    "prepare": "lefthook install || true",
    "release": "bun run build && semantic-release",
    "start": "build-ts run src/index.ts --",
    "start-prod": "bun run build && bun run one-way-git-sync",
    "test": "bun wb test",
    "typecheck": "bun wb typecheck",
    "verify": "bun wb verify",
    "verify-full": "bun wb verify --full"
  },
  "dependencies": {
    "fs-extra": "11.3.6",
    "micromatch": "4.0.8",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "simple-git": "3.36.0",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.10",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/node-ts": "23.6.4",
    "@types/bun": "1.3.14",
    "@types/fs-extra": "11.0.4",
    "@types/micromatch": "4.0.10",
    "@types/node": "25.9.5",
    "@types/yargs": "17.0.35",
    "@willbooster/oxfmt-config": "1.2.2",
    "@willbooster/oxlint-config": "1.4.8",
    "@willbooster/wb": "15.1.1",
    "build-ts": "19.0.0",
    "conventional-changelog-conventionalcommits": "10.2.1",
    "lefthook": "2.1.10",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
    "semantic-release": "25.0.7",
    "sort-package-json": "4.0.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
